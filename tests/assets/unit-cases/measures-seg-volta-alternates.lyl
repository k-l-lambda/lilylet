% measure-layout (segment-wise): volta with alternates. "s: 2*[4]{2 1}" = body of 4
% measures repeated, 1st ending 2 measures, 2nd ending 1 measure. Measures auto-number
% in source order: body=1-4, 1st ending=5-6, 2nd ending=7.
% Index-wise twin: "2*[1..4]{[5,6], 7}".
% Performed order: 1 2 3 4 | 5 6 | 1 2 3 4 | 7
[measures "s: 2*[4]{2 1}"]
c'1 | d'1 | e'1 | f'1 | g'1 | a'1 | b'1 |
